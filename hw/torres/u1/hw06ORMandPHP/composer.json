{
    "name": "american-latin-class/hw06-orm-and-php",
    "description": "American Latin Class PHP API with Slim and Eloquent ORM",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "illuminate/database": "^11.0",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 127.0.0.1:8080 -t public",
        "start:production": "php -S 0.0.0.0:${PORT:-8080} -t public",
        "check": "php -l public/index.php"
    }
}
