@model List<EmployeeManagement.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Employees</h1>
        <a asp-action="Create" asp-controller="Employee" class="btn btn-primary">+ Create Employee</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div id="app">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Phone</th>
                        <th class="text-end">Salary</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var employee in Model)
                        {
                            <tr>
                                <td>@employee.Name</td>
                                <td>@employee.Email</td>
                                <td>@employee.Address</td>
                                <td>@employee.Cellphone</td>
                                <td class="text-end">$@employee.Salary.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-secondary fw-bold">
                    <tr>
                        <td colspan="4" class="text-end">Total Salaries:</td>
                        <td class="text-end">$<span id="totalSalary">@((Model?.Sum(e => e.Salary) ?? 0).ToString("N2"))</span></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="~/js/employee-app.js"></script>
}
