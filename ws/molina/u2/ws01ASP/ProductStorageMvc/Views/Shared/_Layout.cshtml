<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Product Storage</title>

    <link rel="stylesheet" href="~/dist/main.css" asp-append-version="true" />
</head>
<body>
    <header class="main-header">
        <nav class="navbar">
            <a asp-controller="Products" asp-action="Create" class="nav-brand">
                Product Storage
            </a>

            <div class="nav-links">
                <a asp-controller="Products" asp-action="Create">Add Product</a>
                <a asp-controller="Products" asp-action="Index">View Products</a>
            </div>
        </nav>
    </header>

    <main class="page-container">
        @RenderBody()
    </main>

    <script src="~/dist/main.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
