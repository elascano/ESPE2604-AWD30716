@model GestionNominaMVC.Models.Employee

<div class="container mt-4 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="glass-card">
                <div class="text-center mb-5 border-bottom border-light pb-4">
                    <h2 class="display-5 fw-bold text-white mb-0">Register New Employee</h2>
                    <p class="text-white-50 mt-2">Enter the details to add a new member to the company payroll.</p>
                </div>
                
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                    
                    <h4 class="text-info fw-light mb-4"><i class="bi bi-person-badge"></i> Personal Information</h4>
                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control form-control-lg" placeholder="e.g. John" />
                            <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control form-control-lg" placeholder="e.g. Doe" />
                            <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NationalId" class="form-label"></label>
                            <input asp-for="NationalId" class="form-control" placeholder="ID Number" />
                            <span asp-validation-for="NationalId" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="john@example.com" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+1 234 567 8900" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label"></label>
                            <input asp-for="DateOfBirth" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HireDate" class="form-label"></label>
                            <input asp-for="HireDate" class="form-control" />
                            <span asp-validation-for="HireDate" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <h4 class="text-info fw-light mb-4"><i class="bi bi-briefcase"></i> Payroll & Job Details</h4>
                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label asp-for="JobTitle" class="form-label"></label>
                            <input asp-for="JobTitle" class="form-control form-control-lg" placeholder="e.g. Software Engineer" />
                            <span asp-validation-for="JobTitle" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label"></label>
                            <select asp-for="Department" class="form-select form-select-lg">
                                <option value="">Select a department...</option>
                                <option value="IT">IT & Engineering</option>
                                <option value="Sales">Sales & Marketing</option>
                                <option value="HR">Human Resources</option>
                                <option value="Finance">Finance</option>
                                <option value="Operations">Operations</option>
                            </select>
                            <span asp-validation-for="Department" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="col-md-4">
                            <label asp-for="BaseSalary" class="form-label text-white fw-bold"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-dark text-white border-0">$</span>
                                <input asp-for="BaseSalary" class="form-control" step="0.01" />
                            </div>
                            <span asp-validation-for="BaseSalary" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Bonuses" class="form-label text-success"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-dark text-success border-0">+$</span>
                                <input asp-for="Bonuses" class="form-control text-success" step="0.01" />
                            </div>
                            <span asp-validation-for="Bonuses" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Deductions" class="form-label text-danger"></label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-dark text-danger border-0">-$</span>
                                <input asp-for="Deductions" class="form-control text-danger" step="0.01" />
                            </div>
                            <span asp-validation-for="Deductions" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-light">
                        <a asp-action="Index" class="btn btn-outline-light px-4 py-2 rounded-pill">Cancel & Go Back</a>
                        <button type="submit" class="btn btn-glass btn-lg px-5 shadow-lg rounded-pill">Save Employee Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
