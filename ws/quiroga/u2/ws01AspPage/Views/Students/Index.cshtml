@model StudentPortal.Models.DashboardViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Course Dashboard - StudentPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        .card-stats { border-left: 5px solid #0d6efd; }
        .card-best { border-left: 5px solid #198754; }
        .card-worst { border-left: 5px solid #dc3545; }
    </style>
</head>
<body class="bg-light">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">Academic Performance Dashboard</h2>
        <!-- Fixed Register Navigation Link -->
        <a href="/Students/Create" class="btn btn-primary btn-lg shadow-sm">+ Register New Student</a>
    </div>

    <!-- Statistics Cards Section -->
    <div class="row mb-5 g-3">
        <div class="col-md-4">
            <div class="card card-stats shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h6 class="text-uppercase fw-bold text-primary small mb-2">Global Course Average</h6>
                    <div class="display-6 fw-bold text-dark">@Model.CourseAverage</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-best shadow-sm h-100 bg-white">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h6 class="text-uppercase fw-bold text-success small mb-2">Top Performer (Best)</h6>
                    <div class="fs-5 fw-bold text-dark">
                        @if (Model.BestStudent != null)
                        {
                            <span>@Model.BestStudent.FirstName @Model.BestStudent.LastName <span class="badge bg-success ms-2">@Model.BestStudent.Average</span></span>
                        }
                        else
                        {
                            <span class="text-muted">No records yet</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-worst shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h6 class="text-uppercase fw-bold text-danger small mb-2">Underperforming (Worst)</h6>
                    <div class="fs-5 fw-bold text-dark">
                        @if (Model.WorstStudent != null)
                        {
                            <span>@Model.WorstStudent.FirstName @Model.WorstStudent.LastName <span class="badge bg-danger ms-2">@Model.WorstStudent.Average</span></span>
                        }
                        else
                        {
                            <span class="text-muted">No records yet</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Student Table Section -->
    <div class="card shadow-sm border-0">
        <div class="card-header py-3 bg-dark text-white d-flex align-items-center">
            <h5 class="m-0 fw-bold">Enrolled Student Records</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th class="ps-4">Student ID</th>
                            <th>Full Name</th>
                            <th>Math</th>
                            <th>Science</th>
                            <th>History</th>
                            <th>English</th>
                            <th>Programming</th>
                            <th class="text-center table-primary text-dark fw-bold pe-4">Calculated Average</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Students.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5 fs-5">No student data found in the database.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@student.StudentId</strong></td>
                                    <td>@student.LastName, @student.FirstName</td>
                                    <td>@student.Math</td>
                                    <td>@student.Science</td>
                                    <td>@student.History</td>
                                    <td>@student.English</td>
                                    <td>@student.Programming</td>
                                    <td class="table-primary text-center fw-bold pe-4 text-primary">@student.Average</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

</body>
</html>