@model StudentPortal.Models.Student

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Student - StudentPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 text-center">Student Registration Form</h4>
        </div>
        <div class="card-body p-4">
            <!-- Native HTML Form Submission -->
            <form action="/Students/Create" method="post">
                @Html.AntiForgeryToken() <!-- Keeps the form secure and matches the controller -->

                <h5 class="text-primary border-bottom pb-2 mb-3">Personal Information</h5>
                <div class="mb-3">
                    <label class="form-label fw-bold">Student ID / Enrolment</label>
                    <input type="text" name="StudentId" class="form-control" placeholder="e.g. L0012345" required />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">First Name</label>
                        <input type="text" name="FirstName" class="form-control" placeholder="John" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Last Name</label>
                        <input type="text" name="LastName" class="form-control" placeholder="Doe" required />
                    </div>
                </div>

                <h5 class="text-primary border-bottom pb-2 mt-4 mb-3">Academic Grades</h5>
                <div class="row text-secondary">
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">Mathematics</label>
                        <input type="number" name="Math" class="form-control" step="0.01" min="0" max="10" required />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">Science</label>
                        <input type="number" name="Science" class="form-control" step="0.01" min="0" max="10" required />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">History</label>
                        <input type="number" name="History" class="form-control" step="0.01" min="0" max="10" required />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">English</label>
                        <input type="number" name="English" class="form-control" step="0.01" min="0" max="10" required />
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Programming</label>
                        <input type="number" name="Programming" class="form-control" step="0.01" min="0" max="10" required />
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <!-- Fixed Back Button -->
                    <a href="/Students" class="btn btn-outline-secondary px-4">Back to Dashboard</a>
                    <!-- Submit Button -->
                    <button type="submit" class="btn btn-success px-4">Save Student Data</button>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>