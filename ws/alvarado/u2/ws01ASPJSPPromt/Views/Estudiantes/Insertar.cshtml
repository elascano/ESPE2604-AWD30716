@model EstudianteCalificacionViewModel

@{
    ViewData["Title"] = "Add Student";
}

<link rel="stylesheet" href="/css/StylesInsertar.css" />

<h1>Add Student and Grades</h1>

<p><a href="/Estudiantes/Index">← Back to List</a></p>

@if (!ViewData.ModelState.IsValid)
{
    <div style="color:red">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<div id="app">

    <form method="post" action="/Estudiantes/Insertar">

        @Html.AntiForgeryToken()

        <h3>Student Information</h3>

        <div>
            <label for="Nombre">Full Name:</label><br />

            <input id="Nombre"
                   name="Nombre"
                   type="text"
                   v-model="form.nombre"
                   value="@Model.Nombre" />

            <span v-if="errores.nombre" style="color:red">
                {{ errores.nombre }}
            </span>
        </div>

        <br />

        <div>
            <label for="Cedula">ID:</label><br />

            <input id="Cedula"
                   name="Cedula"
                   type="text"
                   v-model="form.cedula"
                   value="@Model.Cedula" />

            <span v-if="errores.cedula" style="color:red">
                {{ errores.cedula }}
            </span>
        </div>

        <br />

        <div>
            <label for="Correo">Email Address:</label><br />

            <input id="Correo"
                   name="Correo"
                   type="email"
                   v-model="form.correo"
                   value="@Model.Correo" />

            <span v-if="errores.correo" style="color:red">
                {{ errores.correo }}
            </span>
        </div>

        <h3>Grades (Range: 1 – 10)</h3>

        <div>
            <label for="Nota1">Grade 1:</label><br />

            <input id="Nota1"
                   name="Nota1"
                   type="number"
                   min="1"
                   max="10"
                   step="0.1"
                   v-model.number="form.nota1"
                   value="@Model.Nota1" />

            <span v-if="errores.nota1" style="color:red">
                {{ errores.nota1 }}
            </span>
        </div>

        <br />

        <div>
            <label for="Nota2">Grade 2:</label><br />

            <input id="Nota2"
                   name="Nota2"
                   type="number"
                   min="1"
                   max="10"
                   step="0.1"
                   v-model.number="form.nota2"
                   value="@Model.Nota2" />

            <span v-if="errores.nota2" style="color:red">
                {{ errores.nota2 }}
            </span>
        </div>

        <br />

        <div>
            <label for="Nota3">Grade 3:</label><br />

            <input id="Nota3"
                   name="Nota3"
                   type="number"
                   min="1"
                   max="10"
                   step="0.1"
                   v-model.number="form.nota3"
                   value="@Model.Nota3" />

            <span v-if="errores.nota3" style="color:red">
                {{ errores.nota3 }}
            </span>
        </div>

        <br />

        <div v-if="form.nota1 && form.nota2 && form.nota3">

            <strong>Calculated Average: {{ promedio }}</strong>

            — 

            <span :style="{ color: promedio >= 7 ? 'green' : 'red' }">

                {{ promedio >= 7 ? 'Passed' : 'Failed' }}

            </span>
        </div>

        <br />

        <button type="submit" @@click.prevent="enviar">
            Save
        </button>

    </form>

</div>

@section Scripts {

<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

<script>

    const { createApp, ref, computed } = Vue;

    createApp({

        setup() {

            const form = ref({

                nombre: '@Html.Raw(Model.Nombre)',
                cedula: '@Html.Raw(Model.Cedula)',
                correo: '@Html.Raw(Model.Correo)',

                nota1: @(Model.Nota1 == 0
                    ? "null"
                    : Model.Nota1.ToString(System.Globalization.CultureInfo.InvariantCulture)),

                nota2: @(Model.Nota2 == 0
                    ? "null"
                    : Model.Nota2.ToString(System.Globalization.CultureInfo.InvariantCulture)),

                nota3: @(Model.Nota3 == 0
                    ? "null"
                    : Model.Nota3.ToString(System.Globalization.CultureInfo.InvariantCulture)),
            });

            const errores = ref({});

            const promedio = computed(() => {

                if (form.value.nota1 &&
                    form.value.nota2 &&
                    form.value.nota3) {

                    return Math.round(

                        (
                            Number(form.value.nota1) +
                            Number(form.value.nota2) +
                            Number(form.value.nota3)
                        ) / 3 * 100

                    ) / 100;
                }

                return null;
            });

            function validar() {

                const e = {};

                if (!form.value.nombre.trim())
                    e.nombre = 'Name is required.';

                if (!form.value.cedula.trim())
                    e.cedula = 'ID is required.';

                if (
                    !form.value.correo.trim() ||
                    !/\S+@@\S+\.\S+/.test(form.value.correo)
                )
                    e.correo = 'Enter a valid email address.';

                ['nota1', 'nota2', 'nota3'].forEach((n, i) => {

                    const v = form.value[n];

                    if (v === null || v === undefined || v === '')
                        e[n] = `Grade ${i + 1} is required.`;

                    else if (v < 1 || v > 10)
                        e[n] = `Grade ${i + 1} must be between 1 and 10.`;
                });

                errores.value = e;

                return Object.keys(e).length === 0;
            }

            function enviar() {

                if (validar()) {
                    document.querySelector('form').submit();
                }
            }

            return {
                form,
                errores,
                promedio,
                enviar
            };
        }

    }).mount('#app');

</script>

}